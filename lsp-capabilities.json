{
  "schema": "OpenQCLspCapabilities",
  "version": 1,
  "id": "gaia-lsp",
  "software": "gaia",
  "displayName": "Gaia Lang",
  "languageId": "python",
  "repository": "newtontech/gaia-lsp",
  "executable": "gaia-lsp",
  "defaultBranch": "main",
  "filePatterns": [
    "pyproject.toml",
    "references.json",
    "src/**/*.py",
    "**/*-gaia/src/**/*.py"
  ],
  "maturity": "alpha",
  "blockingPolicy": {
    "mode": "blocking",
    "description": "Blocking diagnostics indicate Python syntax, invalid Gaia authoring calls, invalid priors, legacy prior dictionaries, or unresolved strict references."
  },
  "capabilities": [
    "agent-envelope",
    "agent-json-cli",
    "blocking-gate",
    "completion",
    "context",
    "definition",
    "diagnostic-engine-v1",
    "diagnostics",
    "explain",
    "hover",
    "import-completion",
    "import-diagnostics",
    "language-manual",
    "manifest",
    "navigation",
    "openqc-context",
    "package-context",
    "quick-fix",
    "references",
    "rich-diagnostics",
    "rule-catalog",
    "routing",
    "signature-help",
    "source-provenance",
    "symbols"
  ],
  "standardLsp": {
    "runtime": "pygls",
    "protocolFamilies": [
      "python",
      "generic-lsp-client"
    ],
    "textDocument": [
      "didOpen",
      "didChange",
      "diagnostic",
      "completion",
      "hover",
      "definition",
      "references",
      "signatureHelp",
      "codeAction",
      "documentSymbol"
    ]
  },
  "agentCli": {
    "command": "gaia-lsp-tool",
    "operations": [
      "capabilities",
      "check",
      "context",
      "complete",
      "definition",
      "hover",
      "manual",
      "explain",
      "references",
      "rules",
      "symbols"
    ],
    "jsonFormat": true,
    "failOnBlocking": true
  },
  "editorExtensions": [
    {
      "editor": "vscode",
      "directory": "gaia-vscode",
      "extensionId": "newtontech.gaia-vscode",
      "marketplace": "https://marketplace.visualstudio.com/items?itemName=newtontech.gaia-vscode",
      "commands": [
        "gaia.lsp.checkFile",
        "gaia.lsp.checkWorkspace",
        "gaia.lsp.showContext",
        "gaia.lsp.showManual",
        "gaia.lsp.showRules"
      ],
      "providers": [
        "diagnostics",
        "completion",
        "hover",
        "definition",
        "references",
        "signatureHelp",
        "codeAction",
        "documentSymbol"
      ]
    }
  ],
  "diagnosticSchema": "diagnostics/diagnostic-engine-v1.schema.json",
  "wikiPaths": {
    "plan": "docs/LLM-WIKI-PLAN.md",
    "rawAssets": "raw/assets",
    "synthesis": "wiki/synthesis",
    "index": "index.md",
    "log": "log.md"
  },
  "fixturePaths": {
    "valid": [
      "tests/fixtures/valid"
    ],
    "invalid": [
      "tests/fixtures/invalid"
    ]
  },
  "openqc": {
    "registryId": "gaia-lsp",
    "repoName": "gaia-lsp",
    "contextContract": "DSLAuthoringContext",
    "diagnosticEnvelope": "DiagnosticEnvelope/v1"
  },
  "sourceProvenance": [
    {
      "id": "gaia-upstream",
      "kind": "upstream_repo",
      "label": "SiliconEinstein/Gaia",
      "url": "https://github.com/SiliconEinstein/Gaia",
      "commit": "6354a3425fdadcf6f7e5f557dd3bc30f36d3297e"
    },
    {
      "id": "gaia-language-reference",
      "kind": "official_docs",
      "label": "Gaia v0.5 Language Reference",
      "url": "https://github.com/SiliconEinstein/Gaia/blob/main/docs/for-users/language-reference.md"
    },
    {
      "id": "gaia-mendel-example",
      "kind": "upstream_example",
      "label": "Mendel v0.5 Gaia example",
      "url": "https://github.com/SiliconEinstein/Gaia/tree/main/examples/mendel-v0-5-gaia"
    }
  ]
}
